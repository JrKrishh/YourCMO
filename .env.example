# ─── YourCMO — AI Marketing Agent ────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Only GOOGLE_AI_STUDIO_API_KEY is required. Everything else is optional.

# ─── LLM (Primary — FREE) ───────────────────────────────────────
# Get key at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key

# ─── LLM Fallbacks (Optional) ───────────────────────────────────
# MiMo V2 Pro — agent brain fallback
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# OpenRouter — free LLM fallback
OPENROUTER_API_KEY=your_openrouter_api_key

# ─── Image & Video Generation (Optional) ────────────────────────
# fal.ai — $10 free credits for video generation (Seedance 2.0)
FAL_KEY=your_fal_ai_key

# ─── Figma API (Optional) ───────────────────────────────────────
# Personal access token for extracting frames from Figma
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=your_figma_access_token

# ─── Agent Configuration ─────────────────────────────────────────
LOG_LEVEL=info
